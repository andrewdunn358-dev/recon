
# SynthOps integration (source of truth for clients/assets/software).
# Create a dedicated SynthOps user for Recon and put its credentials here.
SYNTHOPS_URL=https://synthops.synthesis-it.local
SYNTHOPS_USER=recon@synthesis-it.co.uk
SYNTHOPS_PASSWORD=change-me
# Internal host with a self-signed/internal-CA cert? Either set this to false on
# a trusted LAN, or point SYNTHOPS_CA_BUNDLE at your internal CA .pem to verify.
SYNTHOPS_VERIFY_SSL=false
# SYNTHOPS_CA_BUNDLE=/etc/ssl/certs/synthesis-internal-ca.pem
