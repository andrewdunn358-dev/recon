[Unit]
Description=Recon web (gunicorn)
After=network.target postgresql.service redis-server.service
Requires=postgresql.service redis-server.service

[Service]
Type=simple
User=recon
Group=recon
WorkingDirectory=/opt/recon/control-plane
EnvironmentFile=/opt/recon/control-plane/.env
ExecStart=/opt/recon/control-plane/.venv/bin/gunicorn recon.wsgi:application --bind 0.0.0.0:8000 --workers 3
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
